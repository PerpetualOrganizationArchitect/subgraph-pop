{
  "name": "pop-subgraph",
  "license": "UNLICENSED",
  "scripts": {
    "codegen": "graph codegen",
    "build": "graph build",
    "build:sepolia": "graph build --network sepolia",
    "build:base-sepolia": "graph build --network base-sepolia",
    "deploy:sepolia": "graph deploy --network sepolia --node https://api.studio.thegraph.com/deploy/ poa-sepolia",
    "deploy:base-sepolia": "graph deploy --network base-sepolia --node https://api.studio.thegraph.com/deploy/ poa-base-sepolia",
    "create-local": "graph create --node http://localhost:8020/ poa-sepolia",
    "remove-local": "graph remove --node http://localhost:8020/ poa-sepolia",
    "deploy-local": "graph deploy --node http://localhost:8020/ --ipfs http://localhost:5001 poa-sepolia",
    "test": "graph test --version 0.6.0"
  },
  "dependencies": {
    "@graphprotocol/graph-cli": "^0.98.1",
    "@graphprotocol/graph-ts": "0.37.0"
  },
  "devDependencies": {
    "matchstick-as": "0.6.0"
  }
}
